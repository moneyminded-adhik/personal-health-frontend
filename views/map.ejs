<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Personal Health — Map</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="">
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/public/css/map.css">
  <script src="/config.js"></script>
</head>
<body>
  <div id="map"></div>

  <!-- Top bar -->
  <div class="map-topbar">
    <div class="map-brand">
      <span class="logo-mark">PH</span>
      <span class="logo-name">Map</span>
    </div>
    <div class="map-nav">
      <a href="/" class="map-nav-link">Overview</a>
      <a href="/dashboard" class="map-nav-link">Dashboard</a>
    </div>
    <div class="map-controls">
      <button onclick="recenter()" class="map-btn" title="Re-center on my location">⊙ My Location</button>
    </div>
  </div>

  <!-- Filter pills -->
  <div class="map-filters">
    <button class="pill active" onclick="setFilter('all', this)">All</button>
    <button class="pill" onclick="setFilter('fields', this)">Fields</button>
    <button class="pill" onclick="setFilter('athletes', this)">Athletes</button>
  </div>

  <!-- Status overlay -->
  <div class="map-status" id="map-status">Locating...</div>

  <script>
    const API_BASE = window.AB_CONFIG?.API_BASE || '/api';

    let map = null;
    let userLat = null, userLng = null;
    let fieldMarkers = [], athleteMarkers = [];
    let currentFilter = 'all';

    function makeFieldIcon(name) {
      return L.divIcon({
        className: '',
        html: `<div class="map-marker field-marker" title="${name}">🏟️</div>`,
        iconSize: [36, 36], iconAnchor: [18, 18],
      });
    }

    function makeAthleteIcon(initial, bpi) {
      return L.divIcon({
        className: '',
        html: `<div class="map-marker athlete-marker">${initial}</div>`,
        iconSize: [36, 36], iconAnchor: [18, 18],
      });
    }

    function setStatus(msg) {
      document.getElementById('map-status').textContent = msg;
    }

    function setFilter(f, el) {
      currentFilter = f;
      document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
      el.classList.add('active');

      fieldMarkers.forEach(m => {
        if (f === 'all' || f === 'fields') map.addLayer(m);
        else map.removeLayer(m);
      });
      athleteMarkers.forEach(m => {
        if (f === 'all' || f === 'athletes') map.addLayer(m);
        else map.removeLayer(m);
      });
    }

    function recenter() {
      if (userLat && userLng) {
        map.setView([userLat, userLng], 14);
      } else {
        navigator.geolocation.getCurrentPosition(p => {
          userLat = p.coords.latitude;
          userLng = p.coords.longitude;
          map.setView([userLat, userLng], 14);
        });
      }
    }

    function loadPlayfields(lat, lng) {
      fetch(`${API_BASE}/playfields?lat=${lat}&lng=${lng}&radius=5`)
        .then(r => r.ok ? r.json() : null)
        .then(data => {
          const fields = data?.playfields || data?.fields || [];
          if (!fields.length) {
            setStatus('No fields found nearby');
            return;
          }
          fields.forEach(f => {
            const lat = f.lat || f.latitude;
            const lng = f.lng || f.longitude;
            if (!lat || !lng) return;
            const m = L.marker([lat, lng], { icon: makeFieldIcon(f.name || 'Field') })
              .bindPopup(`<b>${f.name || 'Sports Field'}</b><br>${f.type || ''}`);
            fieldMarkers.push(m);
            m.addTo(map);
          });
          setStatus(`${fields.length} fields nearby`);
        })
        .catch(() => setStatus('Could not load fields'));
    }

    function loadAthletes() {
      fetch(`${API_BASE}/leaderboard`)
        .then(r => r.ok ? r.json() : null)
        .then(data => {
          const athletes = data?.leaderboard || [];
          if (!userLat || !athletes.length) return;
          // Athletes don't have GPS — show top ones near user location as approximate markers
          athletes.slice(0, 5).forEach((a, i) => {
            // Small offset so markers don't stack
            const lat = userLat + (Math.random() - 0.5) * 0.01;
            const lng = userLng + (Math.random() - 0.5) * 0.01;
            const initial = (a.avatar || a.name || '?')[0].toUpperCase();
            const m = L.marker([lat, lng], { icon: makeAthleteIcon(initial) })
              .bindPopup(`<b>${a.name || a.id || 'Athlete'}</b><br>${(a.bpi || 0).toLocaleString()} BPI · ${a.sport || '—'}`);
            athleteMarkers.push(m);
            m.addTo(map);
          });
        })
        .catch(() => {});
    }

    window.onload = () => {
      map = L.map('map', { zoomControl: true, attributionControl: false })
        .setView([20.5937, 78.9629], 5);

      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        maxZoom: 19,
      }).addTo(map);

      // Try geolocation
      if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(
          pos => {
            userLat = pos.coords.latitude;
            userLng = pos.coords.longitude;
            map.setView([userLat, userLng], 14);

            // User dot
            L.circleMarker([userLat, userLng], {
              radius: 8, fillColor: '#06b6d4', color: '#fff',
              weight: 2, fillOpacity: 1,
            }).bindPopup('You are here').addTo(map);

            loadPlayfields(userLat, userLng);
            loadAthletes();
            setStatus('');
          },
          () => {
            setStatus('Location unavailable — showing all of India');
          }
        );
      } else {
        setStatus('Geolocation not supported');
      }
    };
  </script>
</body>
</html>
