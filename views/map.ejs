<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ActiveBharat | Eklavya Map</title>
  <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
  <style type="text/tailwindcss">
    @theme {
      --color-brand: #f97316;
      --color-brand-dark: #ea580c;
      --color-surface: #18181b;
      --color-surface-light: #27272a;
      --color-positive: #22c55e;
      --color-negative: #ef4444;
      --color-warn: #eab308;
      --font-sans: 'Inter', system-ui, sans-serif;
    }
  </style>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="">
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/public/css/map.css">
  <!-- Dynamic runtime config: window.AB_CONFIG.API_BASE available in JS -->
  <script src="/config.js"></script>
</head>
<body class="bg-zinc-950 text-zinc-100 overflow-hidden relative h-[100dvh]" x-data="eklavyaMap()" x-init="initMap()">

  <!-- Map Container -->
  <div id="map"></div>

  <!-- Top UI Bar -->
  <div class="ui-layer top-0 inset-x-0 p-4 flex justify-between items-start bg-gradient-to-b from-black/90 via-black/50 to-transparent pb-16">
    <div class="flex items-center gap-3">
      <button @click="showSettings = true"
        class="w-12 h-12 rounded-full border-2 transition-colors shadow-lg bg-zinc-800 relative group"
        :class="myStatus === 'running' ? 'border-positive' : myStatus === 'lifting' ? 'border-warn' : 'border-blue-500'"
        style="background-image: url('https://i.pravatar.cc/150?u=a042581f4e29026704d'); background-size: cover;">
        <div x-show="isVisible" class="absolute -bottom-1 -right-1 w-4 h-4 rounded-full border-2 border-zinc-950"
          :class="myStatus === 'running' ? 'bg-positive' : myStatus === 'lifting' ? 'bg-warn' : 'bg-blue-500'"></div>
        <div x-show="!isVisible" class="absolute -bottom-1 -right-1 w-5 h-5 bg-zinc-800 rounded-full border border-zinc-600 flex items-center justify-center shadow-lg">
          <span class="text-[10px]">👻</span>
        </div>
      </button>
      <div class="pointer-events-none">
        <div class="text-sm font-bold text-white drop-shadow-md">Arjun Patel <span title="Turf King">👑</span></div>
        <div class="flex items-center gap-2 mt-0.5">
          <span class="text-[10px] font-bold text-brand uppercase tracking-wider bg-black/60 px-2 py-0.5 rounded-full border border-brand/30">Jaipur Javelins</span>
          <span class="text-[10px] font-bold text-zinc-400 bg-black/60 px-2 py-0.5 rounded-full border border-zinc-800">12,450 BPI</span>
        </div>
      </div>
    </div>

    <div class="flex gap-2">
      <a href="/" class="w-10 h-10 rounded-full bg-zinc-900/80 backdrop-blur-md border border-zinc-700 flex items-center justify-center shadow-lg hover:bg-zinc-800 transition-colors text-sm">🏠</a>
      <a href="/dashboard" class="w-10 h-10 rounded-full bg-zinc-900/80 backdrop-blur-md border border-zinc-700 flex items-center justify-center shadow-lg hover:bg-zinc-800 transition-colors text-sm font-bold text-cyan-400">📡</a>
      <button @click="showFriends = true"
        class="w-10 h-10 rounded-full bg-zinc-900/80 backdrop-blur-md border border-zinc-700 flex items-center justify-center shadow-lg hover:bg-zinc-800 transition-colors relative">
        <svg class="w-5 h-5 text-zinc-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <div class="absolute -top-1 -right-1 w-3.5 h-3.5 bg-brand text-white text-[8px] font-bold flex items-center justify-center rounded-full border-2 border-zinc-900">2</div>
      </button>
      <button @click="showLeaderboard = true"
        class="w-10 h-10 rounded-full bg-zinc-900/80 backdrop-blur-md border border-zinc-700 flex items-center justify-center shadow-lg hover:bg-zinc-800 transition-colors">
        <svg class="w-5 h-5 text-yellow-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6m6 0h6m-6 0V9a2 2 0 012-2h2a2 2 0 012 2v10m6 0v-4a2 2 0 00-2-2h-2a2 2 0 00-2 2v4" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Map Filter Pills -->
  <div class="ui-layer top-20 inset-x-0 w-full overflow-x-auto pb-4 no-scrollbar px-4 pointer-events-auto flex justify-start">
    <div class="flex gap-2 whitespace-nowrap">
      <button @click="filter = 'all'" :class="filter === 'all' ? 'bg-zinc-100 text-black border-zinc-100' : 'bg-black/60 text-white border-zinc-700'"
        class="px-3 py-1.5 rounded-full text-xs font-bold border backdrop-blur-md transition-colors shadow-lg">All</button>
      <button @click="filter = 'athletes'" :class="filter === 'athletes' ? 'bg-blue-500 text-white border-blue-400' : 'bg-black/60 text-white border-zinc-700'"
        class="px-3 py-1.5 rounded-full text-xs font-bold border backdrop-blur-md transition-colors shadow-lg">👤 Athletes</button>
      <button @click="filter = 'challenges'" :class="filter === 'challenges' ? 'bg-brand text-white border-brand-dark' : 'bg-black/60 text-white border-zinc-700'"
        class="px-3 py-1.5 rounded-full text-xs font-bold border backdrop-blur-md transition-colors shadow-lg">⚡ Challenges</button>
      <button @click="filter = 'fields'" :class="filter === 'fields' ? 'bg-positive text-white border-green-600' : 'bg-black/60 text-white border-zinc-700'"
        class="px-3 py-1.5 rounded-full text-xs font-bold border backdrop-blur-md transition-colors shadow-lg">🏟️ Fields</button>
      <button @click="filter = 'events'" :class="filter === 'events' ? 'bg-purple-500 text-white border-purple-400' : 'bg-black/60 text-white border-zinc-700'"
        class="px-3 py-1.5 rounded-full text-xs font-bold border backdrop-blur-md transition-colors shadow-lg">🏆 Events</button>
    </div>
  </div>

  <!-- Bottom Action Bar -->
  <div class="ui-layer bottom-0 inset-x-0 p-6 bg-gradient-to-t from-black via-black/90 to-transparent pb-8 pt-20">
    <div class="flex items-center justify-between max-w-sm mx-auto">
      <button @click="showClan = true" class="flex flex-col items-center gap-1 text-zinc-400 hover:text-white transition-colors group">
        <div class="p-2 rounded-xl group-hover:bg-zinc-800/50 transition-colors">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
        </div>
        <span class="text-[10px] font-bold">Clan</span>
      </button>

      <button @click="triggerRally()" class="relative group outline-none">
        <div class="absolute inset-0 bg-brand rounded-full blur-md opacity-50 group-hover:opacity-100 transition-opacity"></div>
        <div class="w-16 h-16 rounded-full bg-gradient-to-br from-brand to-brand-dark flex items-center justify-center relative border-4 border-zinc-950 text-white shadow-xl">
          <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <span class="absolute -bottom-5 left-1/2 -translate-x-1/2 text-[10px] font-bold text-white whitespace-nowrap bg-black/50 px-2 py-0.5 rounded-full">Rally Call</span>
      </button>

      <button class="flex flex-col items-center gap-1 text-brand transition-colors group">
        <div class="p-2 rounded-xl bg-brand/10">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" />
          </svg>
        </div>
        <span class="text-[10px] font-bold">Map</span>
      </button>
    </div>
  </div>

  <script>
    // Dynamic config from Express (no hardcoded IP!)
    const API_BASE = window.AB_CONFIG?.API_BASE || '/api';

    function eklavyaMap() {
      return {
        map: null, filter: 'all',
        myStatus: 'running', isVisible: true, visibilityLevel: 'everyone',
        hasClan: true, currentClanName: 'Jaipur Javelins', mapTheme: 'dark',
        showSettings: false, showFriends: false, showLeaderboard: false, showClan: false,
        activeChallenge: null, showDuelScreen: false, showVictory: false,
        countdown: false, countdownText: '3', challengeData: null,

        initMap() {
          this.map = L.map('map', { zoomControl: false, attributionControl: false }).setView([26.9124, 75.7873], 14);
          this.loadMapTheme('dark');
          this.addMarkers();
          // Fetch live athletes from backend (dynamic!)
          fetch(`${API_BASE}/leaderboard`)
            .then(r => r.ok ? r.json() : null)
            .then(d => { if (d?.athletes) this.addLiveAthletes(d.athletes); })
            .catch(() => {});
        },

        loadMapTheme(theme) {
          const themes = {
            dark:     'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',
            voyager:  'https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png',
            light:    'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png',
            enhanced: 'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
          };
          if (this._tileLayer) this._tileLayer.remove();
          this._tileLayer = L.tileLayer(themes[theme] || themes.dark, { maxZoom: 19 }).addTo(this.map);
          this.mapTheme = theme;
        },

        addMarkers() {
          const makeIcon = (emoji, bg) => L.divIcon({ className: '', html: `<div style="background:${bg};width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;box-shadow:0 2px 8px rgba(0,0,0,.5)">${emoji}</div>` });
          L.marker([26.9024, 75.7773], { icon: makeIcon('⚡','linear-gradient(135deg,#f97316,#ea580c)') }).bindPopup('<b>The Sub-11 Dash</b><br>500 BPI Bounty').addTo(this.map);
          L.marker([26.9224, 75.7973], { icon: makeIcon('🏟️','linear-gradient(135deg,#22c55e,#16a34a)') }).bindPopup('<b>SMS Stadium</b><br>Olympic Training Ground').addTo(this.map);
          L.marker([26.9124, 75.7573], { icon: makeIcon('🏆','linear-gradient(135deg,#a855f7,#9333ea)') }).bindPopup('<b>Rajasthan State Games</b><br>3 days away').addTo(this.map);
        },

        addLiveAthletes(athletes) {
          athletes.slice(0, 5).forEach((a, i) => {
            const lat = 26.9124 + (Math.random()-0.5)*0.02;
            const lng = 75.7873 + (Math.random()-0.5)*0.02;
            const avatar = L.divIcon({ className: '', html: `<div style="width:44px;height:44px;border-radius:50%;border:3px solid #f97316;box-shadow:0 0 15px rgba(249,115,22,0.4);background:url(https://i.pravatar.cc/150?u=${i}) center/cover;"></div>` });
            L.marker([lat, lng], { icon: avatar }).bindPopup(`<b>${a.name||'Athlete'}</b><br>${(a.bpi||0).toLocaleString()} BPI`).addTo(this.map);
          });
        },

        recenterMap() { this.map.setView([26.9124, 75.7873], 14); },
        changeMapTheme(t) { this.loadMapTheme(t); },
        triggerRally() { alert('Rally Call sent! Nearby athletes notified.'); },
        updateAvatarOnMap() { this.isVisible = this.visibilityLevel !== 'ghost'; },

        startCountdown() {
          this.countdown = true; let n = 3;
          this.countdownText = String(n);
          const iv = setInterval(() => {
            n--;
            if (n <= 0) { this.countdownText = 'GO!'; clearInterval(iv);
              setTimeout(() => { this.showDuelScreen = false; this.countdown = false; this.showVictory = true; }, 2000); }
            else { this.countdownText = String(n); }
          }, 1000);
        },
        finishPlay() { this.showVictory = false; }
      };
    }
  </script>
</body>
</html>
