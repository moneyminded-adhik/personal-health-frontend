<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Personal Health</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/public/css/index.css">
  <script src="/config.js"></script>
</head>
<body>

  <% if (!backendOnline) { %>
  <div class="offline-bar">Backend offline — start the Python server to enable live data</div>
  <% } %>

  <nav class="navbar">
    <div class="nav-brand">
      <span class="logo-mark">PH</span>
      <span class="logo-name">Personal Health</span>
    </div>
    <div class="nav-links">
      <a href="/dashboard" class="nav-link">Dashboard</a>
      <a href="/map" class="nav-link">Map</a>
      <a href="/api/status" target="_blank" class="nav-link">API</a>
    </div>
    <div class="nav-right">
      <span class="status-dot <%= backendOnline ? 'online' : 'offline' %>"></span>
      <span class="status-text"><%= backendOnline ? 'Backend online' : 'Offline' %></span>
      <a href="/dashboard" class="btn-nav">Open Dashboard →</a>
    </div>
  </nav>

  <main>
    <!-- Hero -->
    <section class="hero">
      <h1>Sports Biomechanics<br><span class="accent">AI Platform</span></h1>
      <p class="hero-sub">Real-time pose analysis, heart rate monitoring, and session tracking — powered by your phone's camera</p>
      <div class="hero-actions">
        <a href="/dashboard" class="btn-primary">Open Dashboard</a>
        <a href="/map" class="btn-secondary">View Map</a>
      </div>

      <div class="stats-row">
        <div class="stat">
          <div class="stat-val mono"><%= athleteCount > 0 ? athleteCount : '0' %></div>
          <div class="stat-lbl">Athletes</div>
        </div>
        <div class="stat">
          <div class="stat-val mono"><%= activeSessions > 0 ? activeSessions : '0' %></div>
          <div class="stat-lbl">Active Sessions</div>
        </div>
        <div class="stat">
          <div class="stat-val mono"><%= backendOnline ? 'Online' : 'Offline' %></div>
          <div class="stat-lbl">System Status</div>
        </div>
      </div>
    </section>

    <!-- What it does -->
    <section class="features">
      <div class="feature-card">
        <div class="feature-icon">📐</div>
        <h3>Biomechanics Analysis</h3>
        <p>Real-time joint angle tracking and form scoring from the phone camera using MediaPipe pose estimation. Tracks knee, hip, spine, and ankle angles per frame.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">❤️</div>
        <h3>Heart Rate Monitor</h3>
        <p>Remote photoplethysmography (rPPG) via front camera. Measures BPM and HRV by detecting subtle skin colour changes — no wearable needed.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📊</div>
        <h3>Session Tracking</h3>
        <p>Every workout session is recorded with frame-level data. Form scores, peak jump height, symmetry index, and XP earned are stored per athlete.</p>
      </div>
    </section>

    <!-- Top Athletes — server-rendered from /leaderboard -->
    <% if (topAthletes && topAthletes.length > 0) { %>
    <section class="leaderboard">
      <h2>Top Athletes</h2>
      <div class="lb-table">
        <% topAthletes.forEach((a, i) => { %>
        <div class="lb-row">
          <span class="lb-rank <%= i===0?'gold':i===1?'silver':i===2?'bronze':'' %>"><%= i + 1 %></span>
          <span class="lb-avatar"><%= (a.avatar || a.name || '?')[0].toUpperCase() %></span>
          <div class="lb-info">
            <div class="lb-name"><%= a.name || a.id %></div>
            <div class="lb-meta"><%= a.sport || '—' %> · <%= a.tier || 'Athlete' %></div>
          </div>
          <span class="lb-bpi mono"><%= (a.bpi || 0).toLocaleString() %> BPI</span>
        </div>
        <% }); %>
      </div>
      <a href="/dashboard" class="see-all">Full leaderboard in Dashboard →</a>
    </section>
    <% } %>

    <!-- System -->
    <section class="system">
      <h2>System</h2>
      <div class="system-grid">
        <div class="sys-card">
          <div class="sys-label">Android App</div>
          <div class="sys-desc">React Native · Expo SDK 54 · expo-camera</div>
          <div class="sys-tag">Scan QR in Expo Go</div>
        </div>
        <div class="sys-card active">
          <div class="sys-label">Web Frontend</div>
          <div class="sys-desc">Node.js · Express · EJS</div>
          <div class="sys-tag">You are here</div>
        </div>
        <div class="sys-card">
          <div class="sys-label">Backend API</div>
          <div class="sys-desc">FastAPI · MediaPipe · WebSocket</div>
          <a href="<%= config.API_BASE %>/health" target="_blank" class="sys-link">Health check →</a>
        </div>
      </div>
    </section>
  </main>

</body>
</html>
